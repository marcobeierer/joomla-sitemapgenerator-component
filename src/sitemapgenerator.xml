<?xml version="1.0" encoding="utf-8"?>
<extension type="component" version="6.0" method="upgrade">
	<name>com_sitemapgenerator</name>
	<creationDate>June 2026</creationDate>
	<author>Marco Beierer</author>
	<authorEmail>email@marcobeierer.com</authorEmail>
	<authorUrl>https://www.marcobeierer.com</authorUrl>
	<copyright>Copyright (c) 2015 - 2026 Marco Beierer</copyright>
	<license>GNU GPL v3 or later</license>
	<version>2.0.0</version>
	<description>Sitemap Generator component for Joomla.</description>
	<namespace path="src">MarcoBeierer\Component\SitemapGenerator</namespace>

	<administration>
		<menu>Sitemap Generator</menu>
		<files folder="backend">
			<folder>services</folder>
			<folder>src</folder>
			<folder>tmpl</folder>
			<filename>access.xml</filename>
			<filename>config.xml</filename>
		</files>

		<languages folder="language/backend">
			<language tag="en-GB">en-GB/en-GB.com_sitemapgenerator.ini</language>
			<language tag="en-GB">en-GB/en-GB.com_sitemapgenerator.sys.ini</language>
		</languages>
	</administration>

	<media folder="media" destination="com_sitemapgenerator">
		<filename>joomla.asset.json</filename>
		<folder>js</folder>
		<folder>css</folder>
	</media>
</extension>
